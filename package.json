{
  "name": "helene_puiseux",
  "version": "1.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rougerose/helene_puiseux.git"
  },
  "author": "christophe le drean",
  "license": "SEE LICENSE IN README.md",
  "homepage": "https://github.com/rougerose/helene_puiseux",
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "bs": "browser-sync start -c package-scripts/browser-sync.config.js",
    "build": "run-s clean && run-p build:* && run-s css:dev",
    "build:js": "rollup -c package-scripts/rollup.config.js",
    "build:scss": "sass --no-source-map --load-path=node_modules src/scss/index.scss dist/css/helene_puiseux.tmp.css",
    "clean": "rimraf -g 'dist/{css/*,js/*}'",
    "css:dev": "lightningcss --browserslist dist/css/helene_puiseux.tmp.css -o dist/css/helene_puiseux.min.css",
    "css:prod": "lightningcss --minify --browserslist dist/css/helene_puiseux.tmp.css -o dist/css/helene_puiseux.min.css",
    "prod": "run-s clean && NODE_ENV=production run-p build:* && run-s css:prod",
    "watch": "run-p build bs watch:*",
    "watch:css": "chokidar 'src/scss/**/*.scss' -c 'npm run build:scss && npm run css:dev'",
    "watch:js": "chokidar 'src/js/**/*.js' -c 'npm run build:js'"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "chokidar-cli": "^3.0.0",
    "lightningcss-cli": "^1.32.0",
    "npm-run-all2": "^8.0.4",
    "postcss-csso": "^6.0.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-esbuild": "^6.2.1",
    "sass": "^1.79.6"
  }
}
